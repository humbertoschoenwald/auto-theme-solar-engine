#!/usr/bin/env bash
set -euo pipefail

if command -v pnpm >/dev/null 2>&1; then
  PNPM_BIN="pnpm"
elif [[ -n "${APPDATA:-}" && -x "${APPDATA}/npm/pnpm" ]]; then
  PNPM_BIN="${APPDATA}/npm/pnpm"
elif [[ -n "${APPDATA:-}" && -f "${APPDATA}/npm/pnpm.cmd" ]]; then
  PNPM_BIN="${APPDATA}/npm/pnpm.cmd"
else
  echo "pnpm is required to run the pre-push quality gate. Install the repository tooling first."
  exit 1
fi

echo "Running pre-push quality gate..."
"$PNPM_BIN" lint

dotnet restore SolarEngine.slnx
dotnet format SolarEngine.slnx --verify-no-changes --severity error --no-restore
dotnet build SolarEngine.slnx --configuration Release --no-restore --verbosity minimal
dotnet test tests/SolarEngine.Tests/SolarEngine.Tests.csproj --configuration Release --no-build --verbosity minimal

echo "Pre-push validation passed."
