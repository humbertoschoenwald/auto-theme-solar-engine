{
  "name": "dotnet11-cursor-policy-tooling",
  "private": true,
  "scripts": {
    "lint": "npm run lint:eslint && npm run lint:prettier && npm run lint:spelling",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier . --check",
    "lint:prettier:fix": "prettier . --write",
    "lint:spelling": "cspell --no-progress --show-suggestions --cache --relative \"**/*.{cs,csproj,props,targets,slnx,md,txt,json,yml,yaml,ps1}\"",
    "commitlint:last": "commitlint --last --verbose",
    "changelog": "node ./scripts/generate-changelog.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.0.0",
    "cspell-cli": "^9.7.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0"
  }
}
