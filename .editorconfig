#### Manual exception doctrine ####

[src/SolarEngine/UI/NativeInterop.cs]
# Naming is disabled only because authored Win32 identifiers intentionally
# mirror external ABI-defined symbols.
dotnet_diagnostic.IDE1006.severity = none

[src/SolarEngine/Infrastructure/Security/WindowsDataProtection.cs]
# Naming is disabled only because authored DPAPI identifiers intentionally
# mirror external native symbols.
dotnet_diagnostic.IDE1006.severity = none

[src/SolarEngine/Shared/Core/Result.cs]
# Static members on Result<T> are a deliberate ergonomic exception for the
# repository result model.
dotnet_diagnostic.CA1000.severity = none

[tests/**/*.cs]
# Test types are executable collaborators, not published API.
dotnet_diagnostic.CA1515.severity = none
# Test code is not a documentation surface.
dotnet_diagnostic.CS1591.severity = none
