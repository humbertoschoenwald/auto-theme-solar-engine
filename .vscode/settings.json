{
  // Derived from ADR-0000, ADR-0006, ADR-0007, ADR-0008, ADR-0009, ADR-0011, ADR-0015, and ADR-0020.
  // This file is an operational projection of repository doctrine, not an independent policy source.

  "editor.detectIndentation": false,
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.renderWhitespace": "all",

  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.eol": "\n",
  "files.encoding": "utf8",
  "files.hotExit": "off",
  "files.associations": {
    "*.mdc": "markdown"
  },

  "diffEditor.ignoreTrimWhitespace": false,

  "telemetry.telemetryLevel": "off",
  "redhat.telemetry.enabled": false,

  "update.mode": "manual",
  "update.showReleaseNotes": false,
  "extensions.autoUpdate": false,
  "extensions.autoCheckUpdates": false,

  "git.allowNoVerifyCommit": false,
  "git.promptToSaveFilesBeforeCommit": "always",
  "git.promptToSaveFilesBeforeStash": "always",

  "task.saveBeforeRun": "always",
  "testing.saveBeforeTest": true,
  "coverage-gutters.coverageFileNames": ["artifacts/coverage/coverage.xml"],
  "coverage-gutters.showLineCoverage": true,

  "terminal.integrated.confirmOnExit": "hasChildProcesses",
  "terminal.integrated.confirmOnKill": "always",
  "terminal.integrated.enableMultiLinePasteWarning": "always",
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.splitCwd": "inherited",
  "terminal.integrated.detectLocale": "on",
  "terminal.integrated.inheritEnv": true,

  "js/ts.format.enabled": false,
  "js/ts.implicitProjectConfig.checkJs": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "eslint.codeActionsOnSave.mode": "all",
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "prettier.requireConfig": true,
  "prettier.resolveGlobalModules": false,

  "dotnet.defaultSolution": "SolarEngine.slnx",

  "[csharp]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "[python]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "[powershell]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "[shellscript]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[makefile]": {
    "editor.tabSize": 8,
    "editor.insertSpaces": false
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[yaml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[markdown]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  }
}
