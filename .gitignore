# Exclude standard MSBuild and .NET CLI compilation outputs to prevent binary pollution in the repository.
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
artifacts/

# Exclude local NuGet package caches and lock artifacts to guarantee deterministic resolution via CI/CD.
*.nupkg
*.snupkg
.nuget/
project.lock.json
project.fragment.lock.json

# Exclude IDE-specific configuration and temporary workspace files to prevent local developer state from polluting the shared repository.
.vs/
.vscode/*
!.vscode/settings.json
*.user
*.userosscache
*.suo

# Exclude environment variables and secret files unconditionally to strictly enforce zero-trust security and prevent credential leakage.
.env
.env.*
*.secret

# Exclude MSBuild binary logs to prevent accidental disclosure of build-time environment variables and secrets.
*.binlog

# Exclude testing telemetry and coverage reports to prevent repository bloat with ephemeral build artifacts.
[Tt]est[Rr]esult*/
TestResult.xml
CodeCoverage/

# Exclude Node.js dependencies, package manager caches, and transient debug logs.
node_modules/
.npm/
.pnpm-store/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz
npm-cache/

# Exclude Node.js and bundler diagnostic logs.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tsbuildinfo

# Exclude local package manager and tool state.
.parcel-cache/
.cspellcache
.next/
.nuxt/
.svelte-kit/
dist/
coverage/

# Exclude OS-generated indexing and thumbnail artifacts to maintain repository cleanliness.
.DS_Store
Thumbs.db
